{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commander-agent-factory.local/contracts/optimization-plan.schema.json",
  "title": "Optimization Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "target", "baseline_hash", "intent_change", "approved_by_user", "approved_at", "changes", "acceptance", "rollback"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "target": {"type": "string", "minLength": 1},
    "baseline_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "intent_change": {"type": "boolean"},
    "approved_by_user": {"type": "boolean"},
    "approved_at": {"type": ["string", "null"], "format": "date-time"},
    "changes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "acceptance": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "rollback": {"type": "string", "minLength": 1}
  }
}
